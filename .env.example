# ============================================
# Docker Compose 環境変数（サンプル）
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================

# --- ポート設定 ---
NGINX_PORT=8080
MYSQL_PORT=3306
FRONTEND_PORT=3000

# --- MySQL ---
MYSQL_DATABASE=xxx
MYSQL_USER=xxx
MYSQL_PASSWORD=xxx
MYSQL_ROOT_PASSWORD=xxx

# --- フロントエンド ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api
